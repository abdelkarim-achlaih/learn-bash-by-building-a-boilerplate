// The Dev Container format allows you to configure your environment. At the heart of it
// is a Docker image or Dockerfile which controls the tools available in your environment.
//
// See https://aka.ms/devcontainer.json for more information.
{
	"name": "ona-gitpod-compatible",

	"image": "node:18-bullseye",

	"workspaceFolder": "/workspaces/project",

	"overrideCommand": false,

	"postCreateCommand": "touch ~/.bash_history && if [ -f ./freeCodeCamp/.bashrc ]; then cp ./freeCodeCamp/.bashrc ~/.bashrc; fi",

	"postStartCommand": "rm -f ./CHANGELOG.md ./coderoad.yaml ./tutorial.json ./TUTORIAL.md || true",

	"customizations": {
		"vscode": {
			"extensions": ["CodeRoad.coderoad"]
		}
	},

	"remoteUser": "node",

	"shutdownAction": "stopContainer"
}
